{
  "name": "expense-notes",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build && wrangler dev --ip 0.0.0.0",
    "build": "vite build --base=/expense-notes/",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply expense_notes_db --local",
    "db:seed": "wrangler d1 execute expense_notes_db --local --file=./seed/seed.sql",
    "db:reset": "rm -rf .wrangler/state && npm run db:migrate && npm run db:seed",
    "dev:docker": "vite build && npm run db:migrate && npm run db:seed && wrangler dev --ip 0.0.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "typescript": "latest",
    "react": "latest",
    "react-dom": "latest",
    "hono": "latest"
  },
  "devDependencies": {
    "wrangler": "latest"
  }
}
